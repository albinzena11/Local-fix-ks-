# ============================================
# LOCAL-FIX .gitignore - MODIFIKUAR PERFEKT
# ============================================

# 🚨 DEPENDENCIES - KËTO NUK DUHEN NË GIT KURRE!
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm/
.pnpm-store/
*.tgz
*.gz
*.zip

# 🚨 NEXT.JS - SHUMË E RËNDËSISHME
/.next/
/out/
/dist/
.next/cache/
.nx/
.next/server/
.next/static/
.next/types/
.next/server/chunks/
.next/static/chunks/
.next/static/css/
.next/static/media/
.next/static/development/
.next/static/webpack/
.next-analytics/

# 🏗️ BUILD OUTPUTS
/build
/serverless/
.serverless_nextjs/
.next-typescript/

# 📝 LOG FILES - MOS I DËRGONI
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log
logs/
*.logs

# 🔒 ENVIRONMENT FILES - PRIVATE!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env.vault
.local.env
.secrets
.keys

# 🔥 CACHE FOLDERS
.cache/
.turbo/
.vscode/
.idea/
.history/
.parcel-cache/
.eslintcache
.stylelintcache

